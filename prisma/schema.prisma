generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Subject {
  id        String        @id @default(uuid())
  name      String
  color     String        @default("#3b82f6")
  events    Event[]
  sprints   StudySprint[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  isExam      Boolean  @default(false)
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  googleCalId String?  // Stores Google Calendar event ID when synced
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudySprint {
  id           String    @id @default(uuid())
  title        String
  type         String    @default("homework") // class-test | exam | homework | essay | project
  durationMin  Int       @default(25)
  completed    Boolean   @default(false)
  subjectId    String
  subject      Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  userEmail    String    @default("")
  deadline     DateTime?
  remindBefore Int       @default(60) // minutes before deadline to remind
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
